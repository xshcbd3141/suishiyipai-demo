<div class="man_val_fy"></div>
<script>
    var page = 2;
    var isLoading = false; // 新增一个标志变量，表示是否正在加载数据
    window.addEventListener('scroll', function() {
        // 检查特定类名的元素是否可见
        var elements = document.querySelectorAll('.man_val_fy');
        elements.forEach(function(element) {
            var rect = element.getBoundingClientRect();
            if (rect.top >= 0 && rect.bottom <= window.innerHeight) {
                 
                if (!isLoading) {
                    isLoading = true
                    dataHuabanPage();
                }
            }
        });
    });
    function dataHuabanPage() {
        loading = layer.load(2, {
            shade: [0.2, '#000']
        });
        $.ajax({
            type: "POST",
            dataType: "json",
            data:{
                page:page,
            },
            url: "https://pic.51mitu.com/png_Zvdipk8P.html",
            success: function (data) {
                var html = [];
                if(data.data.length == 0){
                    layer.msg('已全部加载完成');
                }else{
                    data.data.forEach(function(vo,i){
                        html += `
                        <div class="gallery-item mixinnet" data="${vo.id}" datam="png">
                            <div class="image-wrapper">
                                <div class="image-wrapper-image">
                                    <div class="positionFixed"></div>
                                    <img src="${vo.pic}" alt="【觅图网-pic.51mitu.com】${vo.title}">
                                </div>
                                <div class="image-overlay">
                                    <div class="image-info">
                                        <a target="_blank" href="${vo.url}">
                                            <h3>${vo.title}</h3>
                                            <p class="dimensions">尺寸:${vo.wh}</p>
                                            <p class="file-size">大小:${vo.size}</p>
                                        </a>
                                        <div class="action-buttons">
                                            <button class="download-btn" onclick="get_dow('png','${vo.id}');">
                                                <i class="fas fa-download"></i> 下载
                                            </button>
                                            <button class="favorite-btn" onclick="get_shoucang('png','${vo.id}');">
                                                <i class="far fa-heart"></i>
                                            </button>
                                            <button class="favorite-btn" onclick="get_canvas_editor('png','${vo['id']}');">
                                                <i class="far fa-edit"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `
                    });
                    $('#gallery').append(html);
                    isLoading = false
                    page ++;
                }
           
                layer.close(loading);
            },
            error : function() {
                layer.close(loading);
                layer.alert('异常', {
                    title: '提示',
                    closeBtn: 0
                });
            }
        });
    }
</script>

