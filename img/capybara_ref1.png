            </svg>
        </button>
        <button onclick="allAdd('900','1200')" class="fixed-btn my-btn" title="编辑器">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" fill="white"/>
            </svg>
        </button>
                <button onclick="authModule('login')" class="fixed-btn my-btn" title="我的">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
            </svg>
        </button>
                <button class="fixed-btn vip-btn" title="VIP" onclick="createVipModal();">
            <svg viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg" fill="currentColor"><path d="M693.333333 375.466667c14.933333 17.066667 12.8 44.8-4.266666 59.733333-115.2 98.133333-238.933333 98.133333-354.133334 0-17.066667-14.933333-19.2-42.666667-4.266666-59.733333 14.933333-17.066667 42.666667-19.2 59.733333-4.266667 83.2 72.533333 160 72.533333 243.2 0 17.066667-14.933333 44.8-12.8 59.733333 4.266667z m51.2-206.933334H279.466667c-14.933333 0-29.866667 8.533333-36.266667 21.333334l-121.6 206.933333c-8.533333 17.066667-6.4 38.4 6.4 51.2l352 371.2c17.066667 17.066667 42.666667 17.066667 59.733333 2.133333l2.133334-2.133333L896 448c12.8-12.8 14.933333-34.133333 6.4-51.2l-121.6-206.933333c-8.533333-12.8-21.333333-21.333333-36.266667-21.333334z m38.4-85.333333c29.866667 0 55.466667 14.933333 72.533334 38.4V128l136.533333 243.2c17.066667 29.866667 12.8 68.266667-8.533333 96l-2.133334 4.266667-407.466666 441.6c-2.133333 2.133333-2.133333 4.266667-4.266667 4.266666-34.133333 29.866667-85.333333 29.866667-117.333333-2.133333l-4.266667-4.266667L42.666667 471.466667c-23.466667-25.6-29.866667-64-12.8-96l2.133333-4.266667L168.533333 128c14.933333-25.6 40.533333-42.666667 70.4-42.666667h544z"/></svg>
        </button>
                <button class="fixed-btn to-top-btn" title="返回顶部" id="toTopBtn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 8l-6 6 1.41 1.41L12 10.83l4.59 4.58L18 14z"/>
            </svg>
        </button>
    </div>
    <div style="display: none;">
            </div>
    <script>
        const createVipJson = {
            monthly: {price: 29, downloads: 100, speed: 20},
            yearly: {price: 99, downloads:  200, speed: 50},
            lifetime: {price: 199, downloads:  300, speed: 100}
        };
        // 返回顶部按钮功能
        const toTopBtn = document.getElementById('toTopBtn');
        
        // 滚动事件监听
        window.addEventListener('scroll', function() {
            if (window.pageYOffset > 300) {
                toTopBtn.classList.add('show');
            } else {
                toTopBtn.classList.remove('show');
            }
        });
        
        // 点击返回顶部
        toTopBtn.addEventListener('click', function() {
            window.scrollTo({
                top: 0,
                behavior: 'smooth'
            });
        });
    </script>
</body>
</html>
